# ═══════════════════════════════════════════════════════════════════════════
# .gitignore — Julio Cepeda Bot
# ═══════════════════════════════════════════════════════════════════════════

# ── SEGURIDAD: Credenciales y secretos ──────────────────────────────────
*.json
!package.json
!package-lock.json
!tests/golden/*.json
!bot/flows/motor/plantillas/*.json
!scripts/ui/estilo_baseline.json
.env
.env.*
!.env.example
*.pem
*.key
*-key.json
*credentials*.json
*service-account*.json
google-vision-key.json
arboreal-pager-497920-c5-af568a08e348.json

# ── DATOS: Archivos locales ────────────────────────────────────────────
# Base de datos SQLite
*.db
*.db-shm
*.db-wal
*.sqlite

# Demo generado (scripts/demo/generar.js) — se regenera, no se versiona.
# Anclado a la raíz para NO ignorar scripts/demo/ (el código sí se versiona).
/demo/
*.sqlite3

# Logs
logs/
*.log
*.log.*

# WhatsApp sesión
.wwebjs_auth/
.wwebjs_cache/
.cache/

# Fotos de clientes (datos personales — nunca al repo)
bot/imagenes_clientes/

# Referencias visuales locales (imágenes de diseño)
Referencias/

# Chrome data
chrome-data/
chrome-profile/

# ── DEPENDENCIAS ───────────────────────────────────────────────────────
node_modules/
npm-debug.log
package-lock.json.bak

# ── COMPILADOS ─────────────────────────────────────────────────────────
dist/
build/
*.exe
*.dll
*.so
*.o

# ── IDEs ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── SISTEMA ───────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
Thumbs.db
ehthumbs.db
Desktop.ini

# ── TEMPORALES ─────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
# Secreto de instancia (por servidor, NO migrar entre despliegues)
dashboard/.instancia_secret

instancias/
dashboard/.instancia_activa

# F5.4: archivero fiscal local (CFDI del PAC) — no se versiona
contabilidad/
restauracion/
stress/
stress-crm/
stress-editor/
stress-bot/
