# .env.example — plantilla. Copia a .env y llena los valores reales.
# El instalador (instalador windows Chatbot.bat) crea .env desde aquí si no existe.

# ── Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_PORT=3001
DASHBOARD_USER=admin
DASHBOARD_PASS=cambiar_esto
# Déjalo vacío/false si el dashboard solo se accede en 127.0.0.1 (default,
# un equipo por tienda vía Electron). Pon "true" solo si el dashboard queda
# detrás de HTTPS real (reverse proxy o acceso por LAN a varias estaciones).
# ⚠️ DEPLOY REMOTO (Oracle/servidor detrás de HTTPS): PON true. Sin esto la
#    cookie de sesión NO lleva la bandera Secure y podría viajar por HTTP.
DASHBOARD_COOKIE_SECURE=false

# ── Deploy remoto (servidor Oracle/Ubuntu detrás de reverse proxy HTTPS) ──
# Interfaz donde escucha el dashboard. Recomendado: dejarlo en 127.0.0.1 y que
# un reverse proxy (Caddy/nginx) termine el TLS y haga proxy a 127.0.0.1:PORT
# — así el proceso Node nunca queda expuesto directo a internet. Solo pon
# 0.0.0.0 si corres en Docker con mapeo de puertos y firewall delante.
DASHBOARD_HOST=127.0.0.1
# Pon 1 SOLO si hay un reverse proxy de confianza delante (Caddy/nginx): así el
# rate-limit y el log usan la IP real del cliente (X-Forwarded-For). Sin proxy
# déjalo vacío/0 — si no, cualquiera podría falsear su IP con ese header.
TRUST_PROXY=0

# Usuario prime — mismo login del dashboard, pero con rol "prime": habilita
# pago_real_activo / estafeta_real_activo (las APIs reales de pago y
# Estafeta) y el costo de envío editable. Déjalo vacío para que ese rol
# quede inalcanzable; solo llénalo cuando se vaya a hacer el piloto real
# con esas APIs ya contratadas.
USER_PRIME=
USER_PRIME_PASSWORD=

# ── Bot / Chrome ───────────────────────────────────────────────────────
# Ruta a chrome.exe o chromium. En Windows el instalador la detecta sola
# si Chrome está en la ruta default. En NixOS es obligatorio definirla.
CHROME_PATH=
ASESOR_WHATSAPP=
# Fijar la versión del front de WhatsApp Web (anti "no descarga medios"). Vacío/
# "auto" = usar la última (hoy funciona con whatsapp-web.js 1.34.x). Si algún día
# WhatsApp publica un cambio que rompe la descarga de medios, pon aquí una versión
# estable conocida (ej. 2.3000.1234567890, de github.com/wppconnect-team/wa-version)
# y reinicia — sin tocar código.
WWEB_WEB_VERSION=
BETA_RESET_CODE=

# ── Soporte del proveedor (widget flotante "Hevcaz Solutions") ──────────
# Contacto al que el operador del negocio escribe para soporte técnico.
# Igual en todas las instancias (es la marca del proveedor, no del cliente).
SOPORTE_HEVCAZ_NOMBRE=Hevcaz Solutions
SOPORTE_HEVCAZ_WHATSAPP=
SOPORTE_HEVCAZ_EMAIL=

# ── Base de datos ──────────────────────────────────────────────────────
DB_PATH=

# ── Negocio ────────────────────────────────────────────────────────────
FLETE_UMBRAL=699

# ── Email (notificaciones de pedidos) ─────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_CEDIS=
EMAIL_PERSONAL=
EMAIL_EXTRA=

# ── Google Cloud Vision (análisis de imágenes) ────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=

NODE_ENV=production

# ── Opcionales (defaults sensatos si se dejan vacíos) ──────────────────
# Bandeja IMAP del módulo Correo (default: imap.gmail.com:993; las
# credenciales del buzón de la tienda van en la BD, Prime > General)
IMAP_HOST=
IMAP_PORT=
# Destino de los respaldos por correo si no se configuró en Prime (email_backup_destino)
BACKUP_DEST=
# Clave maestra (hex) para respaldos cifrados en modo "alto" (no se guarda en BD)
BACKUP_KEY_HEX=
# Token del hub de flota (GET /api/flota/status, header x-flota-token).
# Vacío = endpoint apagado (404)
FLOTA_TOKEN=
