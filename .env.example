# .env.example — plantilla. Copia a .env y llena los valores reales.
# El instalador (instalador windows Chatbot.bat) crea .env desde aquí si no existe.

# ── Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_PORT=3001
DASHBOARD_USER=admin
DASHBOARD_PASS=cambiar_esto
# Déjalo vacío/false si el dashboard solo se accede en 127.0.0.1 (default,
# un equipo por tienda vía Electron). Pon "true" solo si el dashboard queda
# detrás de HTTPS real (reverse proxy o acceso por LAN a varias estaciones).
DASHBOARD_COOKIE_SECURE=false

# Usuario prime — mismo login del dashboard, pero con rol "prime": habilita
# pago_real_activo / estafeta_real_activo (las APIs reales de pago y
# Estafeta) y el costo de envío editable. Déjalo vacío para que ese rol
# quede inalcanzable; solo llénalo cuando se vaya a hacer el piloto real
# con esas APIs ya contratadas.
USER_PRIME=
USER_PRIME_PASSWORD=

# ── Bot / Chrome ───────────────────────────────────────────────────────
# Ruta a chrome.exe o chromium. En Windows el instalador la detecta sola
# si Chrome está en la ruta default. En NixOS es obligatorio definirla.
CHROME_PATH=
ASESOR_WHATSAPP=
BETA_RESET_CODE=

# ── Soporte del proveedor (widget flotante "Hevcaz Solutions") ──────────
# Contacto al que el operador del negocio escribe para soporte técnico.
# Igual en todas las instancias (es la marca del proveedor, no del cliente).
SOPORTE_HEVCAZ_NOMBRE=Hevcaz Solutions
SOPORTE_HEVCAZ_WHATSAPP=
SOPORTE_HEVCAZ_EMAIL=

# ── Base de datos ──────────────────────────────────────────────────────
DB_PATH=

# ── Negocio ────────────────────────────────────────────────────────────
FLETE_UMBRAL=699

# ── Email (notificaciones de pedidos) ─────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_CEDIS=
EMAIL_PERSONAL=
EMAIL_EXTRA=

# ── Google Cloud Vision (análisis de imágenes) ────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=

NODE_ENV=production
